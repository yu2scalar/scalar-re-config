# ScalarRE Kubernetes Environment Variables (host-side companion)
#
# Source from a host shell to populate API_KEY / HMAC_KEY / RE_BASE_URL
# for the Producer and the e2e-test / e2e-replay scripts:
#
#   set -a; source .env; set +a
#
# DB hosts below are K8s Service names — they are only meaningful to
# in-cluster RE pods. Host processes (Producer / e2e) reach the cluster
# through the LoadBalancer at RE_BASE_URL and never touch the DBs directly.

# --- Host ---
JAVA_TOOL_OPTIONS=-Xmx512m
RE_BASE_URL=http://localhost:8080

# --- Authentication ---
SCALAR_RE_API_KEY=change-me

# --- MySQL ---
SCALAR_RE_DB_MYSQL_HOST=mysql
SCALAR_RE_DB_MYSQL_PORT=3306
SCALAR_RE_DB_MYSQL_USERNAME=scalaradmin
SCALAR_RE_DB_MYSQL_PASSWORD=scalaradmin
MYSQL_ROOT_PASSWORD=rootpassword

# --- PostgreSQL ---
SCALAR_RE_DB_POSTGRES_HOST=postgres
SCALAR_RE_DB_POSTGRES_PORT=5432
SCALAR_RE_DB_POSTGRES_DATABASE=db_postgres
SCALAR_RE_DB_POSTGRES_USERNAME=scalaradmin
SCALAR_RE_DB_POSTGRES_PASSWORD=scalaradmin
POSTGRES_ROOT_PASSWORD=rootpassword

# --- DynamoDB Local ---
SCALAR_RE_DB_DYNAMO_REGION=fakeRegion
SCALAR_RE_DB_DYNAMO_ACCESS_KEY=fakeAccessKey
SCALAR_RE_DB_DYNAMO_SECRET_KEY=fakeSecretKey
SCALAR_RE_DB_DYNAMO_ENDPOINT=http://dynamodb:8000

# --- HMAC Keys ---
SCALAR_RE_HMAC_KEY_SCALARRE=demo-hmac-key
SCALAR_RE_HMAC_KEY_NS_MYSQL=demo-hmac-key
SCALAR_RE_HMAC_KEY_NS_POSTGRES=demo-hmac-key
SCALAR_RE_HMAC_KEY_NS_DYNAMO=demo-hmac-key
